# Production site URL (used for SEO canonical URLs and Open Graph)
# Use https://www.foodconsultpro.com when www is your primary GoDaddy CNAME target
NEXT_PUBLIC_SITE_URL=https://www.foodconsultpro.com

# Sticky call & WhatsApp buttons (country code + number, no spaces)
NEXT_PUBLIC_PHONE=919930693061
NEXT_PUBLIC_PHONE_DISPLAY=+91 9930693061

# Office address shown in footer and contact section
NEXT_PUBLIC_OFFICE_ADDRESS=Lodha Signet 1, Unit No. 825, Premier Colony Ground, Thane, 421204

# Public contact email shown on legal pages and footer
NEXT_PUBLIC_CONTACT_EMAIL=hello@foodconsultpro.com

# Grievance officer name for privacy policy (DPDP Act)
NEXT_PUBLIC_GRIEVANCE_OFFICER=FoodConsultPro Support Team

# Google Tag Manager container ID (from https://tagmanager.google.com)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address where form submissions are delivered
CONTACT_EMAIL=foodconsultpro@gmail.com

# Sender address (must be verified in Resend before using your own domain)
# TEST MODE: use onboarding@resend.dev — Resend only delivers to the email you signed up with
# PRODUCTION: verify foodconsultpro.com in Resend, then use hello@foodconsultpro.com
CONTACT_FROM_EMAIL=onboarding@resend.dev
CONTACT_FROM_NAME=FoodConsultPro
